generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A platform user, auto-provisioned on first SSO (or dev) login.
model User {
  id          String          @id @default(cuid())
  email       String          @unique
  name        String
  oid         String?         @unique // Azure AD object id
  role        String          @default("member") // admin | member
  active      Boolean         @default(true)
  avatarUrl   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  apps        App[]           @relation("OwnerApps")
  memberships AppMembership[]
}

/// A connection to an external data source (REST API, PostgreSQL, or SQLite file).
model DataSource {
  id         String   @id @default(cuid())
  name       String
  type       String // REST | POSTGRES | SQLITE
  config     String // encrypted JSON
  ownerId    String?
  visibility String   @default("org") // private | org
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  queries    Query[]
}

/// A saved query/request that runs against a DataSource.
model Query {
  id           String     @id @default(cuid())
  name         String
  dataSourceId String
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  config       String // JSON
  ownerId      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

/// A multi-page app built on the platform.
model App {
  id                 String          @id @default(cuid())
  name               String
  description        String?
  slug               String          @unique
  definition         String // JSON draft: { pages: [...], theme? }
  publishedDefinition String? // JSON snapshot served to runners
  version            Int             @default(0)
  aiConfig           String? // encrypted JSON: per-app AI/agent connection
  visibility         String          @default("private") // private | org | public
  status             String          @default("draft") // draft | deployed
  ownerId            String
  owner              User            @relation("OwnerApps", fields: [ownerId], references: [id])
  deployedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  memberships        AppMembership[]
}

/// Per-app collaborator role. Keyed by email so org members can be added before they log in.
model AppMembership {
  id        String   @id @default(cuid())
  appId     String
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  userEmail String
  role      String // owner | editor | viewer
  user      User?    @relation(fields: [userEmail], references: [email])
  createdAt DateTime @default(now())

  @@unique([appId, userEmail])
}

/// A starter app definition that members can clone into a new app.
model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  definition  String // JSON app definition seed
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Platform-wide settings editable by admins (non-secret).
model Setting {
  key   String @id
  value String // JSON
}
