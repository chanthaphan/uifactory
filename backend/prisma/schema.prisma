generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A platform user, auto-provisioned on first SSO (or dev) login.
model User {
  id          String          @id @default(cuid())
  email       String          @unique
  name        String
  oid         String?         @unique // Azure AD object id
  role        String          @default("member") // admin | member
  active      Boolean         @default(true)
  avatarUrl   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  apps          App[]           @relation("OwnerApps")
  memberships   AppMembership[]
  conversations Conversation[]
}

/// A connection to an external data source, owned by a single app.
model DataSource {
  id        String   @id @default(cuid())
  name      String
  type      String // REST | POSTGRES | SQLITE | MSGRAPH
  config    String // encrypted JSON
  appId     String
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  queries   Query[]

  @@index([appId])
}

/// A saved query/request that runs against a DataSource, owned by a single app.
model Query {
  id           String     @id @default(cuid())
  name         String
  dataSourceId String
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  appId        String
  app          App        @relation(fields: [appId], references: [id], onDelete: Cascade)
  config       String // JSON
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([appId])
}

/// A multi-page app built on the platform.
model App {
  id                  String          @id @default(cuid())
  name                String
  description         String?
  slug                String          @unique
  definition          String // JSON draft: { pages: [...], theme? }
  publishedDefinition String? // JSON snapshot served to runners
  version             Int             @default(0)
  aiConfig            String? // encrypted JSON: per-app AI/agent connection
  visibility          String          @default("private") // private | org | public
  status              String          @default("draft") // draft | deployed
  ownerId             String
  owner               User            @relation("OwnerApps", fields: [ownerId], references: [id])
  deployedAt          DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  memberships         AppMembership[]
  dataSources         DataSource[]
  queries             Query[]
  versions            AppVersion[]
  conversations       Conversation[]
}

/// A persisted chat thread for a signed-in user on a specific chat page.
model Conversation {
  id        String    @id @default(cuid())
  appId     String
  app       App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageId    String? // chat page id within the app definition
  title     String    @default("New chat")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([appId, userId, pageId])
}

/// A single message within a Conversation.
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // user | assistant
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

/// An immutable snapshot of an app definition, captured on each publish — enables rollback.
model AppVersion {
  id          String   @id @default(cuid())
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  version     Int
  definition  String // JSON snapshot of the published definition
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  @@unique([appId, version])
  @@index([appId])
}

/// A platform-wide, admin-curated data-source connection that any app can clone in ("prebuilt connector").
model Connector {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  type        String // REST | POSTGRES | SQLITE | MSGRAPH
  config      String // encrypted JSON (same shape as a DataSource config)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Per-app collaborator role. Keyed by email so org members can be added before they log in.
model AppMembership {
  id        String   @id @default(cuid())
  appId     String
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  userEmail String
  role      String // owner | editor | viewer
  user      User?    @relation(fields: [userEmail], references: [email])
  createdAt DateTime @default(now())

  @@unique([appId, userEmail])
}

/// A starter app definition that members can clone into a new app.
model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  definition  String // JSON app definition seed
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Platform-wide settings editable by admins (non-secret).
model Setting {
  key   String @id
  value String // JSON
}
