# SQLite database used by Prisma to store UIFactory metadata (data sources, queries, apps)
DATABASE_URL="file:./dev.db"

# Port the NestJS API listens on
PORT=3001

# --- AI configuration ---
# The "Generate UI" feature can use Anthropic (Claude), OpenAI, or Azure OpenAI.
# Configure ONE provider below. Without any provider, UIFactory falls back to a
# built-in template generator so the feature still works.
#
# Provider is auto-detected from the keys present (priority: Anthropic, Azure OpenAI, OpenAI).
# Force a specific one with AI_PROVIDER = anthropic | openai | azure-openai
AI_PROVIDER=

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI
AZURE_OPENAI_API_KEY=
# e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=
# the name of your Azure deployment (used as the model)
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
