# SQLite database used by Prisma to store UIFactory metadata (data sources, queries, apps)
DATABASE_URL="file:./dev.db"

# Port the NestJS API listens on
PORT=3001

# --- AI (Claude) configuration ---
# Required to use the "Generate UI" feature. Without it, UIFactory falls back to a
# built-in template generator so the feature still works (without Claude).
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for UI generation
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: override the Anthropic API base URL (e.g. for a gateway/proxy)
# ANTHROPIC_BASE_URL=https://api.anthropic.com
