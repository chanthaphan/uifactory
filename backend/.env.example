# SQLite database used by Prisma to store UIFactory metadata
DATABASE_URL="file:./dev.db"

# Port the NestJS API listens on
PORT=3001

# Frontend origin (used for CORS + OIDC redirects back to the app)
FRONTEND_URL=http://localhost:5173

# Display name of the platform
PLATFORM_NAME=UIFactory

# --- Auth ---
# Secret used to sign session cookies (CHANGE THIS in production)
JWT_SECRET=dev-insecure-uifactory-secret

# Comma-separated emails that should be granted the admin role on first login
ADMIN_EMAILS=

# Azure AD / Entra ID (OIDC). Leave blank to run in DEV MOCK auth mode (local user picker,
# fake org directory). When ALL four are set, real Microsoft sign-in + Graph directory are used.
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=http://localhost:3001/api/auth/callback

# --- AI configuration ---
# The "Generate UI" feature can use Anthropic (Claude), OpenAI, or Azure OpenAI.
# Configure ONE provider below. Without any provider, UIFactory falls back to a
# built-in template generator so the feature still works.
#
# Provider is auto-detected from the keys present (priority: Anthropic, Azure OpenAI, OpenAI).
# Force a specific one with AI_PROVIDER = anthropic | openai | azure-openai
AI_PROVIDER=

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI
AZURE_OPENAI_API_KEY=
# e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=
# the name of your Azure deployment (used as the model)
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
